{
  "name": "alpha-app",
  "version": "0.0.9",
  "scripts": {
    "start": "npm-run-all build-sass --parallel dev",
    "dev": "node --watch build/app.js",
    "build-sass": "rm -rf public/stylesheets/*.css && sass --no-source-map src/frontend-assets/css/index.scss public/stylesheets/styles.css --style compressed",
    "serve": "nodemon serve",
    "precommit": "npm run test && npm run format && git add .",
    "prod": "export NODE_ENV=production && node src/app.ts",
    "test": "node -e \"console.log('No tests currently defined');\"",
    "test:integration:ci": "npm run test:integration:ci:install && npm run test:integration:ci:run",
    "test:integration:ci:install": "npx playwright install --with-deps --only-shell chromium",
    "test:integration:ci:run": "start-server-and-test start http://localhost:3000 test:integration",
    "test:integration": "cucumber-js test/browser/features/v1/analytics --require test/browser/support/setup.ts --require test/browser/step_definitions/**/*.ts cucumber --tags 'not @skip'",
    "prettier": "prettier --write \"**/*.{js,jsx,ts,tsx,md}\"",
    "build": "rm -rf build/ public/ && npm run build-sass && rollup -c",
    "dev-js": "rollup -c --watch"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@govuk-one-login/event-catalogue": "^43.2.0",
    "@govuk-one-login/event-catalogue-schemas": "^43.2.0",
    "@govuk-one-login/event-catalogue-utils": "0.x",
    "@govuk-one-login/frontend-analytics": "4.1",
    "@govuk-one-login/frontend-asset-loader": "0.0.5",
    "@govuk-one-login/frontend-language-toggle": "2.2.2",
    "@govuk-one-login/frontend-logger": "^0.0.2",
    "@govuk-one-login/frontend-ui": "^5.0.0",
    "@govuk-one-login/frontend-vital-signs": "0.1.4",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "dotenv": "^16.4.7",
    "express": "^4.22.2",
    "express-session": "^1.18.2",
    "govuk-frontend": "^5.14.0",
    "helmet": "^8.1.0",
    "i18next": "^23.16.8",
    "i18next-fs-backend": "^2.6.4",
    "i18next-http-middleware": "^3.9.3",
    "nunjucks": "^3.2.4",
    "overload-protection": "^1.2.3",
    "pino": "^10.1.0"
  },
  "peerDependencies": {
    "@govuk-one-login/frontend-logger": "^0.0.2"
  },
  "engines": {
    "node": "24.x"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/govuk-one-login/govuk-one-login-frontend.git",
    "directory": "packages/alpha-app"
  },
  "devDependencies": {
    "@types/chai-subset": "^1.3.6"
  }
}
